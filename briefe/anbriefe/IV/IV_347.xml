   <text>
      <body>
         <pb n="474" facs="#f0474"/>
         <div type="letter">
            <lb xml:id="IV-4_474-2"/>
            <opener>
               <salute>H<hi rendition="#i">errn</hi> Hofrat <hi rendition="#k">Richter</hi> in
              Meinung<hi rendition="#i">en</hi>
               </salute>
               <lb xml:id="IV-4_474-3"/> Lei<hi rendition="#i">p</hi>zig <dateline>10 <hi rendition="#k">Mai</hi>
          1804</dateline>
            </opener>
            <lb xml:id="IV-4_474-4"/>
            <p>Nach Ausstellung des fatalen Wechsels bin ich Ihnen noch 350 rth.<lb n="5" xml:id="IV-4_474-5"/> schuldig, di<hi rendition="#i">e</hi> i<hi rendition="#i">n</hi>
          der Anlage mit</p>
            <lb xml:id="IV-4_474-6"/>
            <p rendition="#c">70. A<hi rendition="#i">lten</hi>
               <hi rendition="#k">Ldors</hi>
            </p>
            <lb xml:id="IV-4_474-7"/>
            <p>folgen.</p>
            <lb xml:id="IV-4_474-8"/>
            <closer>
               <cb/>
               <salute>In gröster Eil<lb/> JFCotta</salute>
            </closer>
         </div>
         <div type="comment">
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Überlieferung</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#i">H: BJK, Berlin A. 1 Bl. 8°,¼ S.</hi>
               </p>
               <lb/>
               <p>
                  <hi rendition="#i">Beilage: 70 Louisd’or, vgl. S. 474,7.</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Erläuterungen</hi>
               </head>
               <p>
                  <hi rendition="#b">474,</hi>
                  <hi rendition="#rkd">5</hi> fatalen Wechsels] <hi rendition="#i">Ein wegen Zahlungsunfähigkeit des letzten Empfängers<lb/> nicht eingelöster Wechsel, vgl. die vorhergehenden Briefe Cottas und die Erläuterung<lb/> zum Brief vom 12. April 1804 (IV 4, 467,15–16, Nr. 340).</hi>
               </p>
            </div>
         </div>
