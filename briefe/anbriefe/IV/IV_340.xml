               <lb xml:id="IV-4_467-26"/>
               <row>
                  <cell/>
                  <cell>Baar hi<hi rendition="#i">er</hi>b<hi rendition="#i">e</hi>i laut Anlage <hi rendition="#u">424.17</hi>
                  </cell>
               </row>
               <lb xml:id="IV-4_467-27"/>
