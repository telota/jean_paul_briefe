                  <hi rendition="#i">B: III 4, 287, Nr. 460 (24.4.1804).</hi>
               </p>
               <lb/>
               <p>
                  <hi rendition="#i">A: III 4, 292–293, Nr. 465 (11.5.1804).</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
