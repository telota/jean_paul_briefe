                  <hi rendition="#i">Mit Korrekturen.</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Varianten</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#b">293,</hi>
                  <hi rendition="#rkd">4</hi> fortführe] <hi rendition="#i">aus</hi> fortfährt <hi rendition="#i">H</hi>
                  <hi rendition="#b">293,</hi>
                  <hi rendition="#rkd">8</hi> Einer] <hi rendition="#i">nachtr. üdZ</hi>
                  <hi rendition="#b">293,</hi>
                  <hi rendition="#rkd">9</hi> hindert]<lb/>
                  <hi rendition="#i">davor üdZ erg. und wieder gestr.</hi> von dort <hi rendition="#i">H</hi>
               </p>
            </div>
