               <p>
                  <hi rendition="#b">313,</hi>
                  <hi rendition="#rkd">33</hi> zu den angenehmsten] <hi rendition="#i">davor gestr.</hi> so <hi rendition="#i">H</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Erläuterungen</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#i">Vgl. Erläuterungen zu B und A.</hi>
               </p>
               <lb/>
               <p>
                  <hi rendition="#b">313,</hi>
                  <hi rendition="#rkd">19–20</hi> der trefflichen <hi rendition="#i">bis</hi> Manne] <hi rendition="#i">Wilhelmine und Friedrich Carl Ferdinand<lb/> von Müffling (vgl. die einleitende Erläuterung zu Nr. 94 sowie B, S. 242,23–25 und<lb/> Erläuterung).</hi>
               </p>
               <lb/>
               <p>
                  <hi rendition="#b">313,</hi>
                  <hi rendition="#rkd">22</hi> Tochter] <hi rendition="#i">Luise von Herder.</hi>
               </p>
            </div>
         </div>
