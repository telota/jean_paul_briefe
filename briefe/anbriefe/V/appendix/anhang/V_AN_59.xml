                  <hi rendition="#i">H: BJK, Berlin A. Billett. Präsentat:</hi> Freitag, den 2. Xbr. 8.</p>
            </div>
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Textgrundlage</hi>
               </head>
