                  <hi rendition="#rkd">24</hi> zwei] <hi rendition="#i">davor gestr.</hi> S <hi rendition="#i">H</hi>
                  <hi rendition="#b">310,</hi>
                  <hi rendition="#rkd">31</hi> setzen] <hi rendition="#i">aus</hi> setzten <hi rendition="#i">H</hi>
                  <hi rendition="#b">311,</hi>
                  <hi rendition="#rkd">12</hi> verstand<lb/>ne] <hi rendition="#i">davor gestr.</hi> gekannte und <hi rendition="#i">H</hi>
                  <hi rendition="#b">311,</hi>
                  <hi rendition="#rkd">13</hi> schrieb] <hi rendition="#i">über gestr.</hi> schib <hi rendition="#i">H</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Erläuterungen</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#b">310,</hi>
                  <hi rendition="#rkd">24</hi> meinem Brief vom 15<hi rendition="#sup">ten</hi>] <hi rendition="#i">Vgl. III 5, 204, Nr. 499.</hi>
               </p>
               <lb/>
               <p>
                  <hi rendition="#b">310,</hi>
                  <hi rendition="#rkd">25–33</hi> Erstlich <hi rendition="#i">bis</hi> vermag] <hi rendition="#i">Vgl. FP 14, vgl. I 14, 10,5–6.</hi>
               </p>
               <lb/>
               <p>
                  <hi rendition="#b">311,</hi>
                  <hi rendition="#rkd">1–4</hi> Zweitens <hi rendition="#i">bis</hi> übersehen] <hi rendition="#i">Vgl. Erläuterung zu S. 221,16–19.</hi>
               </p>
               <lb/>
               <pb n="721" facs="#f0381"/>
               <p>
                  <hi rendition="#b">311,</hi>
                  <hi rendition="#rkd">8</hi> Eben <hi rendition="#i">bis</hi> Arnim] <hi rendition="#i">Vgl. Nr. 165.</hi>
               </p>
               <lb/>
               <p>
                  <hi rendition="#b">311,</hi>
                  <hi rendition="#rkd">8–9</hi> Die erste <hi rendition="#i">bis</hi> beantwortet] <hi rendition="#i">Jean Pauls Antwort auf den Brief Achim von<lb/> Arnims ist nicht überliefert.</hi>
               </p>
               <lb/>
               <p>
                  <hi rendition="#b">311,</hi>
                  <hi rendition="#rkd">12–13</hi> Vorrede <hi rendition="#i">bis</hi> schrieb] <hi rendition="#i">Gemeint ist die Vorrede zu der von Achim von Arnim<lb/> und Clemens Brentano herausgegebenen Sammlung »Des Knaben Wunderhorn. Alte<lb/> deutsche Lieder« (Heidelberg und Frankfurt am Main: Mohr und Zimmer 1806).</hi>
               </p>
