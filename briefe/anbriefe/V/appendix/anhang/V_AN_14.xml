                  <hi rendition="#rkd">12</hi> gegessen] <hi rendition="#i">aus</hi> ges ges <hi rendition="#i">H</hi>
                  <hi rendition="#b">287,</hi>
                  <hi rendition="#rkd">14</hi> nicht] <hi rendition="#i">nachtr.<lb/> üdZ H</hi>
                  <hi rendition="#b">287,</hi>
                  <hi rendition="#rkd">15</hi> ich] <hi rendition="#i">nachtr. üdZ H</hi>
               </p>
            </div>
            <lb/>
