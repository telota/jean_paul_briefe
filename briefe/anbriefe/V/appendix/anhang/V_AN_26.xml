                  <hi rendition="#k">Lesarten</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#b">294,</hi>
                  <hi rendition="#rkd">7</hi> bei mir] bei mir mir <hi rendition="#i">H</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
               <head>
