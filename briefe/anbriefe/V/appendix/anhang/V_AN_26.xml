               </head>
               <lb/>
               <p>
                  <hi rendition="#b">294,</hi>
                  <hi rendition="#rkd">8</hi> jungen, nicht eben bedeutenden] <hi rendition="#i">nachtr. üdZ H</hi>
                  <hi rendition="#b">294,</hi>
                  <hi rendition="#rkd">8–9</hi> auf 4 Uhr]<lb/>
                  <hi rendition="#i">davor gestr.</hi> für <hi rendition="#i">H</hi>
                  <hi rendition="#b">294,</hi>
                  <hi rendition="#rkd">10</hi> u. mich] <hi rendition="#i">davor gestr.</hi> Höre <hi rendition="#i">H</hi>
