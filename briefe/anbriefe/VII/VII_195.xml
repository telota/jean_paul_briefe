                  <hi rendition="#i">Beilage: Ein erster Brief von Henriette Mayer an Caroline Richter (vgl. S. 316,26–<lb/>27).</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Korrespondenzstelle</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#i">B: III 7, 270–273, Nr. 533 (16.–17.6.1819).</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Textgrundlage</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#i">Mit Korrekturen. Textverlust durch Tintenklecks.</hi>
               </p>
               <lb/>
               <p>
                  <hi rendition="#b">318,</hi>
                  <hi rendition="#rkd">13–14</hi> Kaufe <hi rendition="#i">bis</hi> fl.] <hi rendition="#i">S. 4, auR auf dem Kopf stehend.</hi>
               </p>
            </div>
            <lb/>
            <pb n="786" facs="#f0338"/>
            <div type="section">
               <head>
                  <hi rendition="#k">Lesarten</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#b">316,</hi>
                  <hi rendition="#rkd">11</hi> 30<hi rendition="#sup">
                     <hi rendition="#u">ten</hi>
                  </hi>] <hi rendition="#i">doppelt unterstr. H</hi>
                  <hi rendition="#b">316,</hi>
                  <hi rendition="#rkd">12</hi> 16<hi rendition="#sup">
                     <hi rendition="#u">ten</hi>
                  </hi>] <hi rendition="#i">doppelt unterstr. H</hi>
                  <hi rendition="#b">317,</hi>
                  <hi rendition="#rkd">25</hi> vortref<lb/>liche] vortrfliche <hi rendition="#i">H</hi>
                  <hi rendition="#b">317,</hi>
                  <hi rendition="#rkd">25</hi> Töchtern] Töchten <hi rendition="#i">H</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Varianten</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#b">316,</hi>
