                  <hi rendition="#rkd">24</hi> diese.«] diese. <hi rendition="#i">H</hi>
                  <hi rendition="#b">479,</hi>
                  <hi rendition="#rkd">9</hi> Hülfsmittel] Hülsfs mittel <hi rendition="#i">H</hi>
                  <lb/>
                  <hi rendition="#b">479,</hi>
                  <hi rendition="#rkd">32</hi> Aengstlichkeit] Aengestlichkeit <hi rendition="#i">H</hi>
