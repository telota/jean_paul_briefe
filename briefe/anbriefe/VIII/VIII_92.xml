                  <hi rendition="#rkd">14</hi>
                  <hi rendition="#g">ne<lb/>ben Cervantes und Swift,</hi>] <hi rendition="#i">Unterstreichung h<hi rendition="#sup">D</hi>
                  </hi>
                  <hi rendition="#b">176,</hi>
                  <hi rendition="#rkd">20</hi> lieber Richter] <hi rendition="#i">h<hi rendition="#sup">D</hi>
                  </hi>
                  <lb/>
                  <pb n="802" facs="#f0178"/>
                  <hi rendition="#b">176,</hi>
                  <hi rendition="#rkd">21</hi>
                  <hi rendition="#g">Masse</hi>, nach <hi rendition="#g">körperlichem</hi>] <hi rendition="#i">Unterstreichung h<hi rendition="#sup">D</hi>
                  </hi>
                  <hi rendition="#b">176,</hi>
                  <hi rendition="#rkd">25</hi>
                  <hi rendition="#g">größte</hi> und<lb/>
                  <hi rendition="#g">dichteste</hi>] <hi rendition="#i">Unterstreichung h<hi rendition="#sup">D</hi>
                  </hi>
