   <text>
      <body>
         <div type="letter">
            <lb n="15" xml:id="IV-8_448-15"/>
            <opener>Frühlings Erwachen.<lb xml:id="IV-8_448-16"/>
               <dateline>zum 21<hi rendition="#sup">ten</hi> März 1824 dargebracht.</dateline>
            </opener>
            <lb xml:id="IV-8_448-17"/>
            <lg>
               <l>In der stillen Mitternacht</l>
               <lb xml:id="IV-8_448-18"/>
               <l>Saß der Jüngling weint’ und wacht’;</l>
               <lb xml:id="IV-8_448-19"/>
               <l>Denn der Kindheit Rosenblüthe</l>
               <lb n="20" xml:id="IV-8_448-20"/>
               <l>War im Lebenssturm verweht,</l>
               <lb xml:id="IV-8_448-21"/>
               <l>Und, wofür die Seele glühte</l>
               <lb xml:id="IV-8_448-22"/>
               <l>Im herzinnigen Gebet:</l>
               <lb xml:id="IV-8_448-23"/>
               <l>Wahrheit, Licht und Gottesfrieden</l>
               <lb xml:id="IV-8_448-24"/>
               <l>Waren ihm noch nicht beschieden!</l>
            </lg>
            <lb n="25" xml:id="IV-8_448-25"/>
            <lg>
               <l>Wie des Mondes blasser Schein</l>
               <lb xml:id="IV-8_448-26"/>
               <l>Düster in die Nacht hinein,</l>
               <lb xml:id="IV-8_448-27"/>
               <l>Sah er in vergangne Tage,</l>
               <lb xml:id="IV-8_448-28"/>
               <l>Dort auf ferner Zukunft, Flor</l>
               <lb xml:id="IV-8_448-29"/>
               <l>Und der Wehmuth bange Klage</l>
               <lb n="30" xml:id="IV-8_448-30"/>
               <l>Drang aus tiefer Brust hervor:</l>
               <lb xml:id="IV-8_448-31"/>
               <l>All sein Glauben, Hoffen, Sehnen</l>
               <lb xml:id="IV-8_448-32"/>
               <l>Schien ihm nur ein goldnes Wähnen.</l>
            </lg>
            <lb xml:id="IV-8_448-33"/>
            <pb n="449" facs="#f0467"/>
            <lg>
               <l>Eine überblümte Gruft</l>
               <lb xml:id="IV-8_449-1"/>
               <l>War das Leben, Moderduft</l>
               <lb xml:id="IV-8_449-2"/>
               <l>Stieg aus jeder Freudenblume,</l>
               <lb xml:id="IV-8_449-3"/>
               <l>In das hingewelkte Glück</l>
               <lb xml:id="IV-8_449-4"/>
               <l>In der Liebe Heiligthume</l>
               <lb n="5" xml:id="IV-8_449-5"/>
               <l>Ließ nur heißen Schmerz zurück</l>
               <lb xml:id="IV-8_449-6"/>
               <l>Und der Tod mit tausend Armen</l>
               <lb xml:id="IV-8_449-7"/>
               <l>Schien die Welten zu umarmen!</l>
            </lg>
            <lb xml:id="IV-8_449-8"/>
            <lg>
               <l>Sterne blinkten matt und bleich,</l>
               <lb xml:id="IV-8_449-9"/>
               <l>Düstern Grabeslampen gleich,</l>
               <lb n="10" xml:id="IV-8_449-10"/>
               <l>Durch die nebelvollen Räume</l>
               <lb xml:id="IV-8_449-11"/>
               <l>In das Auge thränenschwer,</l>
               <lb xml:id="IV-8_449-12"/>
               <l>Durch die blätterlosen Bäume</l>
               <lb xml:id="IV-8_449-13"/>
               <l>Klagend strich der Nachtwind her,</l>
               <lb xml:id="IV-8_449-14"/>
               <l>Und in namenlosen Wehen</l>
               <lb n="15" xml:id="IV-8_449-15"/>
               <l>Wollte ihm das Herz vergehen.</l>
            </lg>
            <lb xml:id="IV-8_449-16"/>
            <lg>
               <l>Doch wenn andrer Trost gebricht,</l>
               <lb xml:id="IV-8_449-17"/>
               <l>Giebt uns Tugend sanftes Licht;</l>
               <lb xml:id="IV-8_449-18"/>
               <l>Aber ach! Dahingeschwunden</l>
               <lb xml:id="IV-8_449-19"/>
               <l>War der Unschuld Paradies,</l>
               <lb n="20" xml:id="IV-8_449-20"/>
               <l>Und es bluteten die Wunden,</l>
               <lb xml:id="IV-8_449-21"/>
               <l>Die er sich an Dornen riß!</l>
               <lb xml:id="IV-8_449-22"/>
               <l>Ach! Des armen Herzens Fehle</l>
               <lb xml:id="IV-8_449-23"/>
               <l>Drückten schwer die junge Seele!</l>
            </lg>
            <lb xml:id="IV-8_449-24"/>
            <lg>
               <l>Aber mehr als eigner Schmerz</l>
               <lb n="25" xml:id="IV-8_449-25"/>
               <l>Brach des Volkes Weh sein Herz:</l>
               <lb xml:id="IV-8_449-26"/>
               <l>Glaub’ und Freiheit sah er sinken,</l>
               <lb xml:id="IV-8_449-27"/>
               <l>Thronen: Heuchelei und List;</l>
               <lb xml:id="IV-8_449-28"/>
               <l>Sah gezückte Schwerdter blinken,</l>
               <lb xml:id="IV-8_449-29"/>
               <l>Christen wüthen gegen Christ,</l>
               <note corresp="#IV-8_449-30">
                  <listPerson type="lineReference">
                     <person corresp="#JP-000629">
                        <persName>
                           <name type="reg">Christen</name>
                        </persName>
                     </person>
                  </listPerson>
               </note>
               <lb n="30" xml:id="IV-8_449-30"/>
               <l>Finstre Höllenmacht gewinnen</l>
               <lb xml:id="IV-8_449-31"/>
               <l>Und der Wahrheit Licht zerrinnen!</l>
            </lg>
            <lb xml:id="IV-8_449-32"/>
            <pb n="450" facs="#f0468"/>
            <lg>
               <l>Alte Finsterniß umfieng</l>
               <lb xml:id="IV-8_450-1"/>
               <l>Nun den Erdkreis, es verging</l>
               <lb xml:id="IV-8_450-2"/>
               <l>Jede Spur des frischen Lebens;</l>
               <lb xml:id="IV-8_450-3"/>
               <l>Was der hohe Menschengeist</l>
               <lb xml:id="IV-8_450-4"/>
               <l>Schuf und baute war vergebens;</l>
               <lb n="5" xml:id="IV-8_450-5"/>
               <l>Der Gerechte stand verwaist;</l>
               <lb xml:id="IV-8_450-6"/>
               <l>Denn der Lüge freche Rotte</l>
               <lb xml:id="IV-8_450-7"/>
               <l>Opferte dem falschen Gotte.</l>
            </lg>
            <lb xml:id="IV-8_450-8"/>
            <lg>
               <l>Da mit tiefgebeugtem Sinn</l>
               <lb xml:id="IV-8_450-9"/>
               <l>Starrt er in die Nächte hin,</l>
               <lb n="10" xml:id="IV-8_450-10"/>
               <l>Die kein Hoffnungsstern erhellte,</l>
               <lb xml:id="IV-8_450-11"/>
               <l>Sehnte sich umsonst nach Licht,</l>
               <lb xml:id="IV-8_450-12"/>
               <l>Und was seine Seele schwellte:</l>
               <lb xml:id="IV-8_450-13"/>
               <l>Glaub’ und Wahrheit fand er nicht,</l>
               <lb xml:id="IV-8_450-14"/>
               <l>Und den Blick emporgehoben</l>
               <lb n="15" xml:id="IV-8_450-15"/>
               <l>Fleht nach Rettung er von oben!</l>
            </lg>
            <lb xml:id="IV-8_450-16"/>
            <lg>
               <l>Bei der düstern Lampe Schein</l>
               <lb xml:id="IV-8_450-17"/>
               <l>Schläft er unter Thränen ein;</l>
               <lb xml:id="IV-8_450-18"/>
               <l>Aber gräßlicher und wilder,</l>
               <lb xml:id="IV-8_450-19"/>
               <l>Als er wachend sie gesehn</l>
               <lb n="20" xml:id="IV-8_450-20"/>
               <l>Sieht des Lebens finstre Bilder</l>
               <lb xml:id="IV-8_450-21"/>
               <l>Er im Traume vor sich stehn;</l>
               <lb xml:id="IV-8_450-22"/>
               <l>Wie auf sturmbewegten Wogen</l>
               <lb xml:id="IV-8_450-23"/>
               <l>Fühlet er sich fortgezogen.</l>
            </lg>
            <lb xml:id="IV-8_450-24"/>
            <lg>
               <l>Und am starren Felsenriff</l>
               <lb n="25" xml:id="IV-8_450-25"/>
               <l>Dumpfer krachend sinkt das Schiff</l>
               <lb xml:id="IV-8_450-26"/>
               <l>Nieder zu des Meeres Grunde,</l>
               <lb xml:id="IV-8_450-27"/>
               <l>Doch der Fluthen Allgewalt</l>
               <lb xml:id="IV-8_450-28"/>
               <l>Wirft den Jüngling aus dem Schlunde</l>
               <lb xml:id="IV-8_450-29"/>
               <l>An ein Eiland bleich und kalt:</l>
               <lb n="30" xml:id="IV-8_450-30"/>
               <l>Den Verlassenen, den Armen</l>
               <lb xml:id="IV-8_450-31"/>
               <l>Wollte keine Brust erwarmen.</l>
            </lg>
            <lb xml:id="IV-8_450-32"/>
            <pb n="451" facs="#f0469"/>
            <lg>
               <l>Horch! da dringt aus fernen Höhn</l>
               <lb xml:id="IV-8_451-1"/>
               <l>Ein melodisches Getön!</l>
               <lb xml:id="IV-8_451-2"/>
               <l>Süße Frühlingsdüfte wallen</l>
               <lb xml:id="IV-8_451-3"/>
               <l>Durch der Schöpfung weiten Raum,</l>
               <lb xml:id="IV-8_451-4"/>
               <l>Strahlen der Verklärung fallen</l>
               <lb n="5" xml:id="IV-8_451-5"/>
               <l>In den Nachtumhüllten Traum,</l>
               <lb xml:id="IV-8_451-6"/>
               <l>Die entzückten Blicke schauen</l>
               <lb xml:id="IV-8_451-7"/>
               <l>Blüthenreiche Himmelsauen.</l>
            </lg>
            <lb xml:id="IV-8_451-8"/>
            <lg>
               <l>Still im Fluge steht die Zeit!</l>
               <lb xml:id="IV-8_451-9"/>
               <l>Selige Unendlichkeit</l>
               <lb n="10" xml:id="IV-8_451-10"/>
               <l>Ist dem Geiste aufgegangen!</l>
               <lb xml:id="IV-8_451-11"/>
               <l>Von der Erde himmelwärts</l>
               <lb xml:id="IV-8_451-12"/>
               <l>Trägt ein inniges Verlangen</l>
               <lb xml:id="IV-8_451-13"/>
               <l>Sein beglücktes volles Herz:</l>
               <lb xml:id="IV-8_451-14"/>
               <l>Aus des Todes mächt’gen Banden</l>
               <lb n="15" xml:id="IV-8_451-15"/>
               <l>Ist zur Freiheit er erstanden!</l>
            </lg>
            <lb xml:id="IV-8_451-16"/>
            <lg>
               <l>Was ihm trüb’ und dunkel war,</l>
               <lb xml:id="IV-8_451-17"/>
               <l>Wird jetzt sonnenhell und klar!</l>
               <lb xml:id="IV-8_451-18"/>
               <l>Den Gerechten sieht er krönen,</l>
               <lb xml:id="IV-8_451-19"/>
               <l>Unschuld lächeln süße Lust,</l>
               <lb n="20" xml:id="IV-8_451-20"/>
               <l>Friede sieht er sich versöhnen</l>
               <lb xml:id="IV-8_451-21"/>
               <l>Freudeweinend Brust an Brust,</l>
               <lb xml:id="IV-8_451-22"/>
               <l>Und des eignen Herzens Wunden</l>
               <lb xml:id="IV-8_451-23"/>
               <l>Waren durch den Tod geschwunden.</l>
            </lg>
            <lb xml:id="IV-8_451-24"/>
            <lg>
               <l>Liebe, Liebe! klingt es laut,</l>
               <lb n="25" xml:id="IV-8_451-25"/>
               <l>Liebe hat die Welt gebaut,</l>
               <lb xml:id="IV-8_451-26"/>
               <l>Menschen einst zum Glück geboren;</l>
               <lb xml:id="IV-8_451-27"/>
               <l>Wie auch unser Schicksal heißt,</l>
               <lb xml:id="IV-8_451-28"/>
               <l>Wer in Gott, ist unverloren</l>
               <lb xml:id="IV-8_451-29"/>
               <l>Liebe kettet Geist an Geist!</l>
               <lb n="30" xml:id="IV-8_451-30"/>
               <l>Wollt die Gottheit ihr ergründen:</l>
               <lb xml:id="IV-8_451-31"/>
               <l>Liebt! so werdet ihr sie finden!</l>
            </lg>
            <lb xml:id="IV-8_451-32"/>
            <pb n="452" facs="#f0470"/>
            <lg>
               <l>Und mit holdem Friedensgruß</l>
               <lb xml:id="IV-8_452-1"/>
               <l>Neigen sich zum Weihekuß</l>
               <lb xml:id="IV-8_452-2"/>
               <l>Drei ätherische Gestalten:</l>
               <lb xml:id="IV-8_452-3"/>
               <l>Glaube strahlt im Sternenglanz,</l>
               <lb xml:id="IV-8_452-4"/>
               <l>Liebe naht mit Engelswalten,</l>
               <lb n="5" xml:id="IV-8_452-5"/>
               <l>Hoffnung mit dem Siegerkranz,</l>
               <lb xml:id="IV-8_452-6"/>
               <l>Und in sonnenheller Klarheit</l>
               <lb xml:id="IV-8_452-7"/>
               <l>Leuchtet ihm die ew’ge Wahrheit.</l>
            </lg>
            <lb xml:id="IV-8_452-8"/>
            <lg>
               <l>In der Seele Tiefen drang</l>
               <lb xml:id="IV-8_452-9"/>
               <l>Aller Wesen Lobgesang;</l>
               <lb n="10" xml:id="IV-8_452-10"/>
               <l>Edens Frühlingslüfte hauchen</l>
               <lb xml:id="IV-8_452-11"/>
               <l>Nieder frischen Blüthenduft,</l>
               <lb xml:id="IV-8_452-12"/>
               <l>Auf ins Meer des Lichtes tauchen,</l>
               <lb xml:id="IV-8_452-13"/>
               <l>Baden in des Himmels Luft</l>
               <lb xml:id="IV-8_452-14"/>
               <l>Will der Jüngling, auf den Schwingen</l>
               <lb n="15" xml:id="IV-8_452-15"/>
               <l>Hoher Sehnsucht aufwärts dringen!</l>
            </lg>
            <lb xml:id="IV-8_452-16"/>
            <lg>
               <l>Und ein hoher Menschengeist</l>
               <lb xml:id="IV-8_452-17"/>
               <l>Naht sich liebend ihm und heißt</l>
               <lb xml:id="IV-8_452-18"/>
               <l>Folgen ihn auf seinem Zuge,</l>
               <lb xml:id="IV-8_452-19"/>
               <l>Und zu heil’gen Höhen schwingt</l>
               <lb n="20" xml:id="IV-8_452-20"/>
               <l>Er sich auf in stillem Fluge,</l>
               <lb xml:id="IV-8_452-21"/>
               <l>Wo der Stern der Liebe blinkt,</l>
               <lb xml:id="IV-8_452-22"/>
               <l>Wo in ihrem Heiligthume</l>
               <lb xml:id="IV-8_452-23"/>
               <l>Prangt des Lebens schönste Blume.</l>
            </lg>
            <lb xml:id="IV-8_452-24"/>
            <lg>
               <l>Was auf Erden Traumesbild,</l>
               <lb n="25" xml:id="IV-8_452-25"/>
               <l>Sieht er wonnig hier erfüllt:</l>
               <lb xml:id="IV-8_452-26"/>
               <l>Unschuldsvolle Liebe wohnet</l>
               <lb xml:id="IV-8_452-27"/>
               <l>In der schmerzbefreiten Brust,</l>
               <lb xml:id="IV-8_452-28"/>
               <l>Glaub’ und Treue wird belohnet</l>
               <lb xml:id="IV-8_452-29"/>
               <l>Durch des Findens süße Lust,</l>
               <lb n="30" xml:id="IV-8_452-30"/>
               <l>Und der Geist mit Wonnebeben</l>
               <lb xml:id="IV-8_452-31"/>
               <l>Flühet sein unsterblich Leben!</l>
            </lg>
            <lb xml:id="IV-8_452-32"/>
            <pb n="453" facs="#f0471"/>
            <lg>
               <l>Eine hohe Siegesbahn</l>
               <lb xml:id="IV-8_453-1"/>
               <l>Ist dem Kämpfer aufgethan,</l>
               <lb xml:id="IV-8_453-2"/>
               <l>Der auf Erden treu gerungen,</l>
               <lb xml:id="IV-8_453-3"/>
               <l>Aufgeschlossen wird sein Sinn,</l>
               <lb xml:id="IV-8_453-4"/>
               <l>Neuen Lichtes Dämmerungen</l>
               <lb n="5" xml:id="IV-8_453-5"/>
               <l>Ziehn sich durch Äonen hin,</l>
               <lb xml:id="IV-8_453-6"/>
               <l>Und zu neuer Schöpfung Throne</l>
               <lb xml:id="IV-8_453-7"/>
               <l>Wallend, wird er neugeboren!</l>
            </lg>
            <lb xml:id="IV-8_453-8"/>
            <lg>
               <l>Doch ins Erdenthal zurück</l>
               <lb xml:id="IV-8_453-9"/>
               <l>Fiel des Erdenwallers Blick,</l>
               <lb n="10" xml:id="IV-8_453-10"/>
               <l>Das im Reigentanz der Sterne,</l>
               <lb xml:id="IV-8_453-11"/>
               <l>Wie ein blasser voller Mond</l>
               <lb xml:id="IV-8_453-12"/>
               <l>Leuchtete aus weiter Ferne,</l>
               <lb xml:id="IV-8_453-13"/>
               <l>Wo die stille Sehnsucht wohnt:</l>
               <lb xml:id="IV-8_453-14"/>
               <l>Eine Braut des Himmels glänzet</l>
               <lb n="15" xml:id="IV-8_453-15"/>
               <l>Sie durch Nächte sternumkränzet.</l>
            </lg>
            <lb xml:id="IV-8_453-16"/>
            <lg>
               <l>Aber eine Thräne blinkt</l>
               <lb xml:id="IV-8_453-17"/>
               <l>Durch den Schleier ihr und sinkt</l>
               <lb xml:id="IV-8_453-18"/>
               <l>In den Duft der Morgenröthe,</l>
               <lb xml:id="IV-8_453-19"/>
               <l>Die der Berge Gipfel hellt,</l>
               <lb n="20" xml:id="IV-8_453-20"/>
               <l>Wie im kindlichen Gebete</l>
               <lb xml:id="IV-8_453-21"/>
               <l>Dem Beseliger der Welt,</l>
               <lb xml:id="IV-8_453-22"/>
               <l>Aus den Thälern, von den Höhen</l>
               <lb xml:id="IV-8_453-23"/>
               <l>Scheint ihr Lobgesang zu wehen.</l>
            </lg>
            <lb xml:id="IV-8_453-24"/>
            <lg>
               <l>Und der Jüngling fällt entzückt</l>
               <lb n="25" xml:id="IV-8_453-25"/>
               <l>An die Brust des Führers, drückt</l>
               <lb xml:id="IV-8_453-26"/>
               <l>Schweigend ihn in seine Arme,</l>
               <lb xml:id="IV-8_453-27"/>
               <l>Aus des Herzens warmem Schoos</l>
               <lb xml:id="IV-8_453-28"/>
               <l>Windet sich befreit von Harme</l>
               <lb xml:id="IV-8_453-29"/>
               <l>Sanfte Gluth der Liebe los,</l>
               <lb n="30" xml:id="IV-8_453-30"/>
               <l>Und in namenlosen Wonnen</l>
               <lb xml:id="IV-8_453-31"/>
               <l>Ist der Geist in Geist zerronnen.</l>
            </lg>
            <lb xml:id="IV-8_453-32"/>
            <pb n="454" facs="#f0472"/>
            <lg>
               <l>Auf der Töne Wogenfluth</l>
               <lb xml:id="IV-8_454-1"/>
               <l>In des ewgen Morgens Gluth</l>
               <lb xml:id="IV-8_454-2"/>
               <l>Gleiten sie, wie Schwäne nieder,</l>
               <lb xml:id="IV-8_454-3"/>
               <l>Und der Erde Nebelflor</l>
               <lb xml:id="IV-8_454-4"/>
               <l>Ueberwallt die Herzen wieder;</l>
               <lb n="5" xml:id="IV-8_454-5"/>
               <l>Doch die Seele schaut empor</l>
               <lb xml:id="IV-8_454-6"/>
               <l>Und im wilden Weltgetümmel</l>
               <lb xml:id="IV-8_454-7"/>
               <l>Wahrt sie ihren stillen Himmel.</l>
            </lg>
            <lb xml:id="IV-8_454-8"/>
            <lg>
               <l>Ob auch fern der hohe Freund</l>
               <lb xml:id="IV-8_454-9"/>
               <l>Bleibt sie dennoch ihm vereint;</l>
               <lb n="10" xml:id="IV-8_454-10"/>
               <l>Denn auf sehnsuchtsvollem Flügel</l>
               <lb xml:id="IV-8_454-11"/>
               <l>Eilt mit liebetrunknem Sinn</l>
               <lb xml:id="IV-8_454-12"/>
               <l>Selig über Thal und Hügel</l>
               <lb xml:id="IV-8_454-13"/>
               <l>Sie an seinen Busen hin,</l>
               <lb xml:id="IV-8_454-14"/>
               <l>Und in allen Weihestunden</l>
               <lb n="15" xml:id="IV-8_454-15"/>
               <l>Ist sie innig ihm verbunden.</l>
            </lg>
            <lb xml:id="IV-8_454-16"/>
            <lg>
               <l>Es entwich der goldne Traum!</l>
               <lb xml:id="IV-8_454-17"/>
               <l>Aber in des Stübleins Raum</l>
               <lb xml:id="IV-8_454-18"/>
               <l>Fallen Aufgangs-Sonnenstrahlen,</l>
               <lb xml:id="IV-8_454-19"/>
               <l>Linde weht die Himmelsluft,</l>
               <lb n="20" xml:id="IV-8_454-20"/>
               <l>Von den Bergen, aus den Thalen</l>
               <lb xml:id="IV-8_454-21"/>
               <l>Wallt empor der Opferduft;</l>
               <lb xml:id="IV-8_454-22"/>
               <l>Denn aus morgenrothen Thoren</l>
               <lb xml:id="IV-8_454-23"/>
               <l>Stieg der Frühling neugeboren.</l>
            </lg>
            <lb xml:id="IV-8_454-24"/>
            <lg>
               <l>Und ein neues Leben regt</l>
               <lb n="25" xml:id="IV-8_454-25"/>
               <l>Sich im Busen tief bewegt,</l>
               <lb xml:id="IV-8_454-26"/>
               <l>Mit den Lerchen will er singen,</l>
               <lb xml:id="IV-8_454-27"/>
               <l>Die von saatengrünen Feld</l>
               <lb xml:id="IV-8_454-28"/>
               <l>Jubelnd sich zum Himmel schwingen,</l>
               <lb xml:id="IV-8_454-29"/>
               <l>Auf zum Vater Seiner Welt,</l>
               <lb n="30" xml:id="IV-8_454-30"/>
               <l>Der im ew’gen Lichte wohnet</l>
               <lb xml:id="IV-8_454-31"/>
               <l>Und mit Huld und Liebe thronet.</l>
            </lg>
            <lb xml:id="IV-8_454-32"/>
            <pb n="455" facs="#f0473"/>
            <lg>
               <l>Und der Glocken Ruf erschallt</l>
               <lb xml:id="IV-8_455-1"/>
               <l>Mit einladender Gewalt! –</l>
               <lb xml:id="IV-8_455-2"/>
               <l>Hin zu Seines Namens Feier</l>
               <lb xml:id="IV-8_455-3"/>
               <l>Wandelt froh die Geisterschaar</l>
               <lb xml:id="IV-8_455-4"/>
               <l>Und die Seele kummerfreier</l>
               <lb n="5" xml:id="IV-8_455-5"/>
               <l>Opfert gläubig am Altar:</l>
               <lb xml:id="IV-8_455-6"/>
               <l>Gottes Frieden säuselt nieder</l>
               <lb xml:id="IV-8_455-7"/>
               <l>Kehret in die Herzen wieder.</l>
            </lg>
            <lb xml:id="IV-8_455-8"/>
            <lg>
               <l>Aus der Seele quillt das Wort,</l>
               <lb xml:id="IV-8_455-9"/>
               <l>Rauschend trägts die Orgel fort</l>
               <lb n="10" xml:id="IV-8_455-10"/>
               <l>Zu dem hohen Wolkensitze!</l>
               <lb xml:id="IV-8_455-11"/>
               <l>Heilige Gewitter ziehn</l>
               <lb xml:id="IV-8_455-12"/>
               <l>Durch die Brust, erhabne Blitze</l>
               <lb xml:id="IV-8_455-13"/>
               <l>Aus der Ewigkeit durchglühn</l>
               <lb xml:id="IV-8_455-14"/>
               <l>Die Gemüther, und das Sehnen</l>
               <lb n="15" xml:id="IV-8_455-15"/>
               <l>Glänzt im reinen Thau der Thränen!</l>
            </lg>
            <lb xml:id="IV-8_455-16"/>
            <lg>
               <l>Zu des Morgens goldnem Thor</l>
               <lb xml:id="IV-8_455-17"/>
               <l>steigt des Jünglings Dank empor;</l>
               <lb xml:id="IV-8_455-18"/>
               <l>Denn das heißgeliebte Leben,</l>
               <lb xml:id="IV-8_455-19"/>
               <l>Das sein glühend Herz umfängt,</l>
               <lb n="20" xml:id="IV-8_455-20"/>
               <l>Dem die zarten Saiten beben,</l>
               <lb xml:id="IV-8_455-21"/>
               <l>Den der Geist in Wonne denkt,</l>
               <lb xml:id="IV-8_455-22"/>
               <l>Den er liebend sich erkohren,</l>
               <lb xml:id="IV-8_455-23"/>
               <l>Ward in seinem Strahl geboren!</l>
            </lg>
            <lb xml:id="IV-8_455-24"/>
            <lg>
               <l>Und er fleht mit Andachtsblick</l>
               <lb n="25" xml:id="IV-8_455-25"/>
               <l>Von der Gottheit: Heil und Glück,</l>
               <lb xml:id="IV-8_455-26"/>
               <l>Fleht des Segens reiche Fülle</l>
               <lb xml:id="IV-8_455-27"/>
               <l>Nieder auf das theure Haupt,</l>
               <lb xml:id="IV-8_455-28"/>
               <l>Das mit ewig frischer Hülle</l>
               <lb xml:id="IV-8_455-29"/>
               <l>Hohen Ruhmes Kranz umlaubt!</l>
               <lb n="30" xml:id="IV-8_455-30"/>
               <l>Und in himmlischer Verklärung</l>
               <lb xml:id="IV-8_455-31"/>
               <l>Winken Engel ihm Gewährung!</l>
            </lg>
            <lb xml:id="IV-8_455-32"/>
            <pb n="456" facs="#f0474"/>
            <lg>
               <l>Hätt’ ich Gold und Edelstein,</l>
               <lb xml:id="IV-8_456-1"/>
               <l>Wollt’ ich Dirs zum Opfer weihn:</l>
               <lb xml:id="IV-8_456-2"/>
               <l>Wonne meiner Lebenstage!</l>
               <lb xml:id="IV-8_456-3"/>
               <l>Aber nur ein liebend Herz</l>
               <lb xml:id="IV-8_456-4"/>
               <l>Ist es, was ich zu Dir trage,</l>
               <lb n="5" xml:id="IV-8_456-5"/>
               <l>Ewig Dein in Lust und Schmerz!</l>
               <lb xml:id="IV-8_456-6"/>
               <l>Und Du Guter! Läßt das Lallen</l>
               <lb xml:id="IV-8_456-7"/>
               <l>Heißer Liebe Dir gefallen!</l>
            </lg>
            <lb xml:id="IV-8_456-8"/>
            <lg>
               <l>Der Du mich im Traumgesicht</l>
               <lb xml:id="IV-8_456-9"/>
               <l>Hingeführt zu ew’gem Licht,</l>
               <lb n="10" xml:id="IV-8_456-10"/>
               <l>Bleib’ mir liebend zugewendet!</l>
               <lb xml:id="IV-8_456-11"/>
               <l>Wenn der Zukunft Schleier fällt,</l>
               <lb xml:id="IV-8_456-12"/>
               <l>Wenn die Pilgerfahrt vollendet:</l>
               <lb xml:id="IV-8_456-13"/>
               <l>Grüß’ ich Dich in bessrer Welt,</l>
               <lb xml:id="IV-8_456-14"/>
               <l>Der Du mich aus dunklem Tode</l>
               <lb n="15" xml:id="IV-8_456-15"/>
               <l>Wecktest: holder Frühlingsbote! –</l>
            </lg>
            <lb xml:id="IV-8_456-16"/>
            <p>Nur noch ein Wort laß mich reden, Du hoher Freund! Ver<lb xml:id="IV-8_456-17" rendition="#hyphen"/>schmähe nicht das Lallen eines Kindes, das sich mit seinen klei<lb xml:id="IV-8_456-18" rendition="#hyphen"/>nen Händen am Saume Deines Kleides fest hält und hinauf will<lb xml:id="IV-8_456-19"/> auf Deinen Schoos und an Deine Brust, wenn es auch seine<lb n="20" xml:id="IV-8_456-20"/> Freude nur durch ein Lächeln und durch schwache Laute
              kund<lb xml:id="IV-8_456-21"/> giebt. Ich kann weiter nichts, als Dir die Worte
            nachsagen: »Ach,<lb xml:id="IV-8_456-22"/> auf meine Flecken und dunkle Stellen dreh’
            ich zu leicht und<lb xml:id="IV-8_456-23"/> schmerzend mein Auge; doch ein Lichtpunkt
            blinkt wie Dia<lb xml:id="IV-8_456-24" rendition="#hyphen"/>mantfeuer an mir, die Liebe zu Dir! –« Noch
            einmal grüße ich<lb n="25" xml:id="IV-8_456-25"/> Dich, Du hohes liebendes Menschenherz
            und alle Deine Theu<lb xml:id="IV-8_456-26" rendition="#hyphen"/>ren! Meine Seele ist bei Dir, und jede
            Freude meines Lebens<lb xml:id="IV-8_456-27"/> erhöht das Andenken an Deine Liebe! –</p>
            <lb xml:id="IV-8_456-28"/>
            <closer>
               <cb/>
               <salute>Eduard Pohl.<note corresp="#IV-8_456-29-r">
                     <listPerson type="lineReference"/>
                  </note>
                  <lb xml:id="IV-8_456-29-r"/> Frau Präsidentin v Fischer, Hr.
                Professor<note corresp="#IV-8_456-29">
                     <listPerson type="lineReference">
                        <person corresp="#JP-001088">
                           <persName>Frau von <name type="reg">Fischer</name>
                           </persName>
                        </person>
                        <person corresp="#JP-004133">
                           <persName>Henrik <name type="reg">Steffens</name>
                           </persName>
                        </person>
                     </listPerson>
                  </note>
                  <lb xml:id="IV-8_456-29"/> Steffens und Hr. Buchhändler Max<note corresp="#IV-8_456-30">
                     <listPerson type="lineReference">
                        <person corresp="#JP-002693">
                           <persName>Joseph <name type="reg">Max</name>
                           </persName>
                        </person>
                     </listPerson>
                  </note>
                  <lb n="30" xml:id="IV-8_456-30"/> grüßen herzlich, Letzterer sehnt sich<lb xml:id="IV-8_456-31"/> nach einer Antwort von Dir.</salute>
            </closer>
         </div>
