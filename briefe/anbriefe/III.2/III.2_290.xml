                  <hi rendition="#k">Textgrundlage</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#i">Grundsätzliches zu den Briefen von Paul Emile Thieriot vgl. IV 3.1, 428, Nr. 6, Ab<lb/>schnitt Textgrundlage. Mit Korrekturen.</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Lesarten</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#b">131,</hi>
                  <hi rendition="#rkd">4</hi>
                  <hi rendition="#g">wahrer</hi>] <hi rendition="#i">doppelt unterstr. K</hi>
               </p>
            </div>
            <lb/>
            <pb n="564" facs="#f0123"/>
            <div type="section">
               <head>
                  <hi rendition="#k">Varianten</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#b">130,</hi>
                  <hi rendition="#rkd">25</hi> Abschieds] <hi rendition="#i">nachtr. üdZ K</hi>
                  <hi rendition="#b">130,</hi>
                  <hi rendition="#rkd">26</hi> wenig als] <hi rendition="#i">danach gestr.</hi> einen <hi rendition="#i">K</hi>
                  <lb/>
                  <hi rendition="#b">130,</hi>
                  <hi rendition="#rkd">30–31</hi> abforderten und] <hi rendition="#i">üdZ K</hi>
                  <hi rendition="#b">130,</hi>
                  <hi rendition="#rkd">32</hi> wie Neeb.] <hi rendition="#i">danach gestr.</hi> Die 2 Zei<lb/>len, die ich noch daraus weiß, will ich Ihnen schreiben: <hi rendition="#i">K</hi>
                  <hi rendition="#b">131,</hi>
                  <hi rendition="#rkd">2</hi> noch oft]<lb/>
                  <hi rendition="#i">üdZ aus gestr.</hi> zuweilen <hi rendition="#i">K</hi>
                  <hi rendition="#b">131,</hi>
                  <hi rendition="#rkd">5</hi>
                  <hi rendition="#g">griechisch</hi> –] <hi rendition="#i">danach gestr.</hi> darin ist er eben<lb/> zu einheimisch geworden <hi rendition="#i">K</hi>
                  <hi rendition="#b">131,</hi>
                  <hi rendition="#rkd">7</hi> undefinirte] <hi rendition="#i">nachtr. üdZ K</hi>
                  <hi rendition="#b">131,</hi>
                  <hi rendition="#rkd">8–9</hi> Er<lb/> lachte längst über mein 15jähriges »Bewustseyn des Bewustseins.«] <hi rendition="#i">nachtr.<lb/> üdZ K</hi>
                  <hi rendition="#b">131,</hi>
                  <hi rendition="#rkd">16</hi> ungezogenen] <hi rendition="#i">nachtr. üdZ K</hi>
                  <hi rendition="#b">131,</hi>
                  <hi rendition="#rkd">18</hi>
                  <hi rendition="#k">pati</hi>
                  <hi rendition="#i">u.</hi>
                  <hi rendition="#k">facere posse</hi>] <hi rendition="#i">aus</hi>
