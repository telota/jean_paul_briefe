               </head>
               <lb/>
               <p>
                  <hi rendition="#b">388,</hi>
                  <hi rendition="#rkd">24</hi> künftige] <hi rendition="#i">üdZ H</hi>
                  <hi rendition="#b">388,</hi>
                  <hi rendition="#rkd">25</hi> unter] <hi rendition="#i">danach gestr.</hi> meine <hi rendition="#i">H</hi>
                  <hi rendition="#b">388,</hi>
                  <hi rendition="#rkd">25</hi> die]<lb/>
