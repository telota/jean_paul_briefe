                  <hi rendition="#b">388,</hi>
                  <hi rendition="#rkd">28</hi> Verhältnis] <hi rendition="#i">danach gestr.</hi> steht <hi rendition="#i">H</hi>
                  <lb/>
                  <hi rendition="#b">388,</hi>
                  <hi rendition="#rkd">34</hi> diese Voraussetzung] <hi rendition="#i">üdZ, darunter gestr.</hi> der Ausdruck <hi rendition="#i">H</hi>
                  <lb/>
                  <hi rendition="#b">389,</hi>
                  <hi rendition="#rkd">1</hi> indem] <hi rendition="#i">üdZ, darunter gestr.</hi> da <hi rendition="#i">H</hi>
                  <hi rendition="#b">389,</hi>
                  <hi rendition="#rkd">2</hi> er den Briefsteller] <hi rendition="#i">üdZ H</hi>
                  <lb/>
                  <hi rendition="#b">389,</hi>
                  <hi rendition="#rkd">5</hi> mein] <hi rendition="#i">üdZ H</hi>
                  <hi rendition="#b">389,</hi>
                  <hi rendition="#rkd">12–13</hi> das Publikum] <hi rendition="#i">üdZ, darunter gestr.</hi> andere <hi rendition="#i">H</hi>
