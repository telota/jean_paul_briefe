   <text>
      <body>
         <pb n="28" facs="#f0054"/>
         <div type="letter">
            <lb xml:id="IV-9_28-7"/>
            <p>Herzlichen Dank für Ihr Zutrauen u. Ihre Freude, welches Sie<lb xml:id="IV-9_28-8"/>
              mir beides schenkten</p>
            <lb xml:id="IV-9_28-9"/>
            <closer>
               <cb/>
               <salute>R.</salute>
            </closer>
         </div>
         <pb n="99" facs="#f0125"/>
         <div type="comment">
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Überlieferung</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#i">H: SBa, Signatur: OFS.Autogr. R 1(1809.12.04. Billett, ½ S.</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Textgrundlage</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#i">Mit Korrekturen.</hi>
               </p>
               <lb/>
               <p>
                  <hi rendition="#i">Über dem Präsentat vfrH (Emanuel?) »<hi rendition="#k">Altensteins</hi> Brf.«.</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Varianten</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#b">28,</hi>
                  <hi rendition="#rkd">8</hi> Ihr] <hi rendition="#i">über gestr.</hi> das <hi rendition="#i">H</hi>
                  <hi rendition="#b">28,</hi>
                  <hi rendition="#rkd">8</hi> Ihre] <hi rendition="#i">über gestr.</hi> die <hi rendition="#i">H</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Erläuterungen</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#i">Die Notiz über dem Präsentat lässt vermuten, dass Emanuel einen Brief des preußi<lb/>schen Staatsministers Karl Freiherr von Stein zum Altenstein (1770–1840), der sein<lb/> Amt 1808 angetreten hatte, an Jean Paul weitergereicht hatte.</hi>
               </p>
            </div>
         </div>
      </body>
