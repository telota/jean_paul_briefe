   <text>
      <body>
         <div type="letter">
            <lb xml:id="IV-9_37-2"/>
            <p>Guten Morgen u Dank, mein <hi rendition="#k">Emanuel</hi>! Hier Rückfracht, die
                Sie<lb xml:id="IV-9_37-3"/> jedes mal – wenn Sie sonst wollen – an <hi rendition="#k">Otto</hi> ablaufen lassen.</p>
         </div>
         <div type="comment">
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Überlieferung</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#i">H: SBa, Signatur: OFS.Autogr. R 1(1822.03.26. Billett, ½ S.</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Datum</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#i">Präsentat: 26 &lt;verb. aus 27&gt; Mart. 22</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Textgrundlage</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#i">Mit Korrektur.</hi>
               </p>
            </div>
            <lb/>
            <pb n="119" facs="#f0145"/>
            <div type="section">
               <head>
                  <hi rendition="#k">Varianten</hi>
               </head>
               <lb/>
               <p>
                  <hi rendition="#b">37,</hi>
                  <hi rendition="#rkd">3–4</hi> Sie jedes] <hi rendition="#i">über gestr.</hi> alle <hi rendition="#i">H</hi>
               </p>
            </div>
            <lb/>
            <div type="section">
               <head>
                  <hi rendition="#k">Erläuterungen</hi>
               </head>
               <p>
                  <hi rendition="#b">37,</hi>
                  <hi rendition="#rkd">3</hi> Rückfracht] <hi rendition="#i">Vermutlich Briefe, die unter den Freunden herumgereicht wur<lb/>den.</hi>
               </p>
               <lb/>
               <p>
                  <hi rendition="#b">37,</hi>
                  <hi rendition="#rkd">4</hi>
                  <hi rendition="#k">Otto</hi>] <hi rendition="#i">Der gemeinsame Freund Christian Otto.</hi>
               </p>
            </div>
         </div>
      </body>
