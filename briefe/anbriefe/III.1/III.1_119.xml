               <p>
                  <hi rendition="#b">217,</hi>
                  <hi rendition="#rkd">10</hi> – Ich] Ich <hi rendition="#i">D<hi rendition="#sup">2</hi>
                  </hi>
                  <hi rendition="#b">217,</hi>
                  <hi rendition="#rkd">15</hi> ist?] ist. <hi rendition="#i">D<hi rendition="#sup">2</hi>
                  </hi>
