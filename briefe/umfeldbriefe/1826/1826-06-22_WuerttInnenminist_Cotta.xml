   <text>
      <body>
         <div type="writingSession" xml:id="Schreibakt_1">
            <pb n="1"/>
            <opener>
               <dateline/>
               <salute>
                  <hi rendition="#c">
                     <hi rendition="#aq">
                        <seg type="comment">
                           <orig>Das<lb/>
                                        Ministerium des Innern <lb/> an.</orig>
                           <note xml:id="nyj3_jph_fxb">Vorgedruckt auf Briefbogen des
                                        Württembergischen
                            Innenministeriums.</note>
                        </seg>
                     </hi>
                     <lb/>den Freiherrn <hi rendition="#aq">Cotta von Cottendorf</hi>,<lb/>K. Preußischen
                            Geheimen Hofrath, dahier.</hi>
               </salute>
            </opener>
            <p>
               <seg type="comment">
                  <orig>Die Eingabe der <persName key="JP-000704">J. G.
                                Cotta'schen Buchhandlung</persName> dahier vom 9. März d.
                            J.,</orig>
                  <note xml:id="nogg_vph_fxb">Nicht überliefert.</note>
               </seg>
                    betreffend der Wahrung ihrer Ansprüche auf das Verlagsrecht von mehreren
                    einzelnen Schriften des nun verstorbenen Legationsraths <hi rendition="#aq">
                  <persName key="JP-999999">Jean Paul Richter</persName>
               </hi> in
                    Beziehung auf das zum Vortheil der hinterlassenen Familie desselben verwilligte
                    Privilegium gegen den Nachdruck einer neuen Ausgabe seiner <bibl sameAs="JP-010983" subtype="werke-jp">sämtlichen Werke</bibl>, hat man <seg type="comment">
                  <orig>seiner <persName key="JP-003469">Wittwe</persName>
                  </orig>
                  <note xml:id="ndjv_rph_fxb">Caroline Richter.</note>
               </seg>
                    in <placeName key="JP-005574">Baireuth</placeName> zugehen lassen. Nach <seg type="comment">
                  <orig>ihrer unter dem 17. d. M. hierauf eingekommenen
                            Erklärung</orig>
                  <note xml:id="nyfg_5ph_fxb">
                     <ref type="letter" target="JP-UB0371">Caroline Richters Brief an die Württembergische
                                Regierung vom 26. Mai 1826</ref>.</note>
               </seg> glaubt diesselbe von
                    dem eigenen Gutdünken des Inhabers jener Buchhandlung eine dem mit demselben
                    seit vielen Jahren bestehenden wohlwollenden und freundschaftlichen Verhältnisse
                    entsprechende Erledigung erwarten zu dürfen.</p>
            <p>
               <anchor type="target" xml:id="start_xh2_5pc_pzb"/>Indem nun ihrem ausdrücklichen
                    Verlangen gemäß dem Freiherrn <hi rendition="#aq">Cotta von Cottendorf</hi>
                    diese Erklärung in dem Anschlusse mitgetheilt wird,<anchor type="target" xml:id="stop_xh2_5pc_pzb"/> sieht man der Erledigung der Sache in dem von
                    der <persName key="JP-003469">Wittwe Richter</persName> einge<pb n="2"/>schlagenen Wege der Güte, im Anstandsfall aber der weiteren Aeusserung des
                    Freiherrn Cotta von Cottendorf entgegen.</p>
            <closer>
               <dateline>
                  <hi rendition="#c">Stuttgart den 22. <hi rendition="#aq">Jun</hi>.
                            1826.</hi>
               </dateline>
               <salute/>
               <signed>
                  <hi rendition="#right">
                     <seg type="comment">
                        <orig>
                           <persName key="JP-014512">Schmidlin</persName>
                        </orig>
                        <note xml:id="nrzy_jrh_fxb">Der Innenminister des Königreichs
                                    Württemberg, Christoph Friedrich
                                        von Schmidlin.</note>
                     </seg>
                  </hi>
               </signed>
            </closer>
            <postscript>
               <p/>
            </postscript>
