   <text>
      <body>
         <div type="writingSession" xml:id="Schreibakt_1">
            <pb n="1"/>
            <opener>
               <dateline>Leipzig den <subst>
                     <del rendition="#s">29. August</del>
                     <add place="superlinear" hand="#author">5. Septbr.</add>
                  </subst> 1806.</dateline>
               <salute/>
            </opener>
            <p>Erscheinet auf mündliche Vorladung <lb/>
               <hi rendition="#c">Herrn <persName key="JP-002583">Siegfried August Mahlmann</persName>
                  <lb/>
                  <seg type="comment">
                     <orig>Herzoglich Säch. Gothaischer
                                Hofrath,</orig>
                     <note xml:id="nhw4_xwc_xyb">In anderer Schrift
                                geschrieben.</note>
                  </seg>
               </hi>
               <lb/>und erkläret, daß er die Vormundschaft der <seg type="comment">
                  <orig>von
                            dem verstorbenen Fürst<ex>lich</ex> Neuwiedischen Hofrathe, Herrn
                                <persName key="JP-004104">Carl Spazier</persName>
                  </orig>
                  <note xml:id="nax4_x1d_xyb">Spazier war am 19. Januar 1805
                        gestorben.</note>
               </seg> hinterlassenen, mit der Ehegenossin, Frauen
                        <persName key="JP-004393">Johanne Caroline Wilhelmine gebohrene
                        Meyer</persName> erzeugten unmündigen Kinder,</p>
            <p>
               <table rows="4" cols="5">
                  <row>
                     <cell>
                        <space unit="section"/>
                     </cell>
                     <cell>
                        <persName key="JP-004106">Julius Adolphs</persName>
                     </cell>
                     <cell>von</cell>
                     <cell>9</cell>
                     <cell>Jahren</cell>
                  </row>
                  <row>
                     <cell/>
                     <cell>
                        <persName key="JP-004103">Marien Emma Auguste</persName>
                     </cell>
                     <cell>  "</cell>
                     <cell>7½</cell>
                     <cell>Jahren</cell>
                  </row>
                  <row>
                     <cell/>
                     <cell>
                        <persName key="JP-000009">Laura Minona</persName>
                     </cell>
                     <cell>  "</cell>
                     <cell>5½</cell>
                     <cell>Jahren</cell>
                  </row>
                  <row>
                     <cell/>
                     <cell>
                        <persName key="JP-004107">Richard Ottos</persName>
                     </cell>
                     <cell>  "</cell>
                     <cell>3½</cell>
                     <cell>Jahren</cell>
                  </row>
               </table>
            </p>
            <p>auf das Vorschlagen ihrer <persName key="JP-004393">Frau Mutter</persName>
                    übernehmen wolle, und er hat das Beste seiner Pflegbefohlnen mit Treue und
                    Sorgfalt zu beobachten, dasjenige, was von ihrem Vermögen in seine Hände kommen
                    dürfte, gebührend zu verwalten und zu berechnen, auch dieserhalb sein eigenes
                    Vermögen zu einem ausdrücklichen Unterpfande einzusetzen versprochen, sowohl
                    hierüber das gewöhnliche Angelöbniß geleistet, worauf der Herr <persName key="JP-002583">Hofrath Mahlmann</persName> wegen der Bestätigung an F. E.
                    Hochweisen Rath gewiesen worden ist. <foreign xml:lang="Lat">
                  <seg type="comment">
                     <orig>Actum in praes:</orig>
                     <note xml:id="nj5z_tyc_xyb">Lat.:
                                geschehen in Anwesenheit von.</note>
                  </seg>
               </foreign>
               <hi rendition="#aq">Depp</hi>. </p>
            <closer>
               <salute/>
               <signed>Herrn <persName key="JP-014864">OHGRth D. Siegmanns</persName>, und
                        Herrn Baum<ex>ei</ex>ster <persName key="JP-014843">Mangelsdorff</persName>
                  <hi rendition="#right">Christian Fürchtegott
                                Schröder</hi>
               </signed>
               <dateline> den 5 <hi rendition="#aq">Sept. 1806</hi>. </dateline>
            </closer>
            <postscript>
               <p/>
            </postscript>
